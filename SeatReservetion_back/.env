# =============================================================================
# Переменные окружения для системы бронирования рабочих мест
# =============================================================================
# Данный файл содержит конфигурационные параметры приложения
# ВАЖНО: Не коммитьте этот файл в систему контроля версий в продакшене!
# =============================================================================

# Настройки базы данных SQLite (PostgreSQL)
DATABASE_URL=sqlite:///./seat_reservation.db
# Формат: postgresql://username:password@host:port/database_name

# Настройки безопасности и аутентификации
# Секретный ключ для подписи JWT токенов (ОБЯЗАТЕЛЬНО измените в продакшене!)
SECRET_KEY=0898a3c320a097a9c984a7039eec9f54a92176d8bd6fd2d44f4861990b673578

# Алгоритм подписи JWT токенов
ALGORITHM=HS256

# Время жизни access токена в минутах
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Настройки приложения
# Режим отладки (True/False)
DEBUG=False

# Название приложения
APP_NAME=Seat Reservation API

# Версия приложения
APP_VERSION=1.0.0

# Настройки CORS
# Разрешенные источники для Cross-Origin Resource Sharing
ALLOWED_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000","http://localhost:5173","http://127.0.0.1:5173"]

# Настройки логирования
# Уровень логирования: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Часовой пояс приложения
TIMEZONE=UTC

# =============================================================================
# НАСТРОЙКИ EMAIL / SMTP
# =============================================================================
# SMTP сервер для отправки уведомлений по email
# Для Gmail: используйте App Password (не обычный пароль)
# https://myaccount.google.com/apppasswords

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@seatreservation.com
SMTP_FROM_NAME=Seat Reservation System
SMTP_USE_TLS=True

# =============================================================================
# ИНСТРУКЦИЯ ПО ИСПОЛЬЗОВАНИЮ:
# 1. Скопируйте этот файл как .env в корневую директорию проекта
# 2. Измените SECRET_KEY на уникальное значение в продакшене
# 3. Настройте DATABASE_URL под вашу базу данных
# 4. Настройте ALLOWED_ORIGINS под ваш фронтенд домен
# =============================================================================